{
    "typ": "trening",
    "info": "Klon profilu EfficientNet-B2",
    "description": "Klon profilu EfficientNet-B2",
    "data_required": "38 klas, 95 obrazów treningowych i 5 walidacyjnych na klasę",
    "hardware_required": "GPU RTX 4700, RYZEN 9 16-rdzeniowy, RAM 128GB",
    "config": {
        "model": {
            "architecture": "EfficientNet",
            "variant": "EfficientNet-B2",
            "input_size": 288,
            "num_classes": 35
        },
        "training": {
            "epochs": 180,
            "batch_size": 32,
            "learning_rate": 0.0002,
            "optimizer": "AdamW",
            "scheduler": "CosineAnnealingWarmRestarts",
            "num_workers": 12,
            "warmup_epochs": 10,
            "mixed_precision": true,
            "freeze_base_model": true,
            "unfreeze_layers": 12,
            "unfreeze_strategy": "Stopniowo po 15 epokach"
        },
        "regularization": {
            "weight_decay": 0.0001,
            "gradient_clip": 1.0,
            "label_smoothing": 0.15,
            "drop_connect_rate": 0.3,
            "dropout_rate": 0.5,
            "momentum": 0.9,
            "epsilon": 1e-06,
            "swa": {
                "use": true,
                "start_epoch": 80
            }
        },
        "augmentation": {
            "basic": {
                "use": true,
                "rotation": 30,
                "brightness": 0.3,
                "contrast": 0.3,
                "shift": 0.15,
                "zoom": 0.2,
                "horizontal_flip": true,
                "vertical_flip": false
            },
            "mixup": {
                "use": true,
                "alpha": 0.4
            },
            "cutmix": {
                "use": true,
                "alpha": 1.0
            },
            "autoaugment": {
                "use": true
            },
            "randaugment": {
                "use": true,
                "n": 3,
                "m": 9
            },
            "trivialaugment": {
                "use": true
            }
        },
        "preprocessing": {
            "normalization": "ImageNet",
            "scaling": {
                "method": "Bicubic",
                "maintain_aspect_ratio": true,
                "pad_to_square": true,
                "pad_mode": "reflection",
                "pad_value": 0
            }
        },
        "monitoring": {
            "metrics": {
                "accuracy": true,
                "precision": true,
                "recall": true,
                "f1": true,
                "topk": true,
                "confusion_matrix": true
            },
            "early_stopping": {
                "patience": 25,
                "min_delta": 0.001,
                "monitor": "val_f1"
            },
            "checkpointing": {
                "best_only": true,
                "save_frequency": 1,
                "metric": "val_f1"
            },
            "tensorboard": {
                "use": true,
                "log_dir": "logs/efficientnet"
            },
            "save_dir": "checkpoints/efficientnet",
            "save_logs": true
        },
        "advanced": {
            "scheduler": {
                "T_0": 10,
                "T_mult": 2,
                "eta_min": 1e-07
            },
            "weights": {
                "init_method": "kaiming_normal",
                "freeze_cnn": false,
                "pretrained": true
            },
            "cross_validation": {
                "use": true,
                "folds": 5
            },
            "distributed": {
                "use": false,
                "backend": "nccl",
                "strategy": "ddp"
            },
            "gradients": {
                "clip": 1.0,
                "accumulation": 4
            },
            "online_validation": {
                "use": true,
                "frequency": 2
            }
        }
    }
}