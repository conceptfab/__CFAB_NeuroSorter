{
  "type": "fine_tuning",
  "info": "Profil dla klasyfikacji jednoklasowej (binarnej)",
  "description": "Profil dostosowany do wykrywania pojedynczej klasy (tak/nie)",
  "data_required": "Zestaw danych zawierający przykłady pozytywne i negatywne",
  "hardware_required": "Standardowy sprzęt",
  "config": {
    "model": {
      "architecture": "EfficientNet",
      "variant": "EfficientNet-B2",
      "input_size": 288,
      "num_classes": 2,
      "pretrained": true,
      "pretrained_weights": "imagenet",
      "feature_extraction_only": false,
      "activation": "relu",
      "dropout_at_inference": false,
      "global_pool": "avg",
      "last_layer_activation": "sigmoid"
    },
    "training": {
      "epochs": 100,
      "batch_size": 48,
      "learning_rate": 0.0002,
      "optimizer": "AdamW",
      "scheduler": "CosineAnnealingWarmRestarts",
      "num_workers": 4,
      "warmup_epochs": 10,
      "warmup_lr_init": 1e-06,
      "mixed_precision": true,
      "gradient_accumulation_steps": 1,
      "gradient_clip": 1.0,
      "validation_split": 0.2,
      "evaluation_freq": 1,
      "use_ema": false,
      "ema_decay": 1.0,
      "unfreeze_strategy": "unfreeze_all",
      "unfreeze_after_epochs": 5,
      "unfreeze_layers": 12,
      "frozen_lr": 0.0,
      "unfrozen_lr": 0.0
    },
    "regularization": {
      "weight_decay": 0.0001,
      "label_smoothing": 0.05,
      "dropout_rate": 0.4,
      "drop_connect_rate": 0.3,
      "momentum": 0.9,
      "epsilon": 1e-06,
      "swa": {
        "use": true,
        "start_epoch": 80
      },
      "stochastic_depth": {
        "use": false,
        "drop_rate": 0.2,
        "survival_probability": 0.8
      },
      "random_erase": {
        "use": false,
        "probability": 0.25,
        "mode": "pixel"
      }
    },
    "augmentation": {
      "basic": {
        "use": true,
        "rotation": 30,
        "brightness": 0.3,
        "shift": 0.15,
        "zoom": 0.2,
        "horizontal_flip": true,
        "vertical_flip": false
      },
      "mixup": {
        "use": false,
        "alpha": 0.2
      },
      "cutmix": {
        "use": false,
        "alpha": 0.5
      }
    },
    "preprocessing": {
      "normalization": "RGB",
      "resize_mode": "bilinear",
      "cache_dataset": false
    },
    "monitoring": {
      "metrics": {
        "accuracy": true,
        "precision": true,
        "recall": true,
        "f1": true,
        "topk": false,
        "confusion_matrix": true,
        "auc": true
      },
      "logging": {
        "use_tensorboard": true,
        "use_wandb": false,
        "save_to_csv": true,
        "logging_freq": "epoch"
      },
      "visualization": {
        "use_gradcam": true,
        "use_feature_maps": true
      },
      "early_stopping": {
        "use": true,
        "patience": 10,
        "min_delta": 0.001,
        "monitor": "val_loss",
        "mode": "min"
      }
    }
  }
}