{
  "type": "fine_tuning",
  "info": "Profil do doszkalania modelu 5-klasowego (EfficientNet-B2)",
  "description": "Zoptymalizowany profil doszkalania dla klasyfikacji 5 klas z wysoką dokładnością",
  "data_required": "Zbiór danych z 5 klasami, zalecane minimum 50 obrazów na klasę",
  "hardware_required": "GPU z minimum 6GB pamięci",
  "config": {
    "model": {
      "architecture": "EfficientNet",
      "variant": "EfficientNet-B2",
      "input_size": 288,
      "num_classes": 5,
      "pretrained": true,
      "pretrained_weights": "imagenet",
      "feature_extraction_only": false,
      "activation": "swish",
      "dropout_at_inference": false,
      "global_pool": "avg",
      "last_layer_activation": "softmax"
    },
    "training": {
      "epochs": 25,
      "batch_size": 16,
      "learning_rate": 0.0001,
      "optimizer": "AdamW",
      "scheduler": "CosineAnnealingWarmRestarts",
      "num_workers": 4,
      "warmup_epochs": 3,
      "warmup_lr_init": 1e-6,
      "mixed_precision": true,
      "gradient_accumulation_steps": 2,
      "gradient_clip": 1.0,
      "validation_split": 0.2,
      "evaluation_freq": 1,
      "use_ema": true,
      "ema_decay": 0.9995,
      "unfreeze_strategy": "unfreeze_gradual_end",
      "unfreeze_after_epochs": 3,
      "unfreeze_layers": 8,
      "frozen_lr": 0.00005,
      "unfrozen_lr": 0.0002
    },
    "regularization": {
      "weight_decay": 0.0001,
      "label_smoothing": 0.05,
      "dropout_rate": 0.3,
      "drop_connect_rate": 0.2,
      "momentum": 0.9,
      "epsilon": 1e-6,
      "swa": {
        "use": true,
        "start_epoch": 15
      },
      "stochastic_depth": {
        "use": false,
        "drop_rate": 0.1,
        "survival_probability": 0.9
      },
      "random_erase": {
        "use": true,
        "probability": 0.15,
        "mode": "pixel"
      }
    },
    "augmentation": {
      "basic": {
        "use": true,
        "rotation": 20,
        "brightness": 0.2,
        "shift": 0.1,
        "zoom": 0.15,
        "horizontal_flip": true,
        "vertical_flip": false
      },
      "mixup": {
        "use": true,
        "alpha": 0.2
      },
      "cutmix": {
        "use": true,
        "alpha": 0.5
      }
    },
    "preprocessing": {
      "normalization": {
        "mean": [0.485, 0.456, 0.406],
        "std": [0.229, 0.224, 0.225]
      },
      "resize_mode": "bilinear",
      "cache_dataset": true
    },
    "monitoring": {
      "metrics": {
        "accuracy": true,
        "precision": true,
        "recall": true,
        "f1": true,
        "topk": true,
        "confusion_matrix": true,
        "auc": true
      },
      "logging": {
        "use_tensorboard": true,
        "use_wandb": false,
        "save_to_csv": true,
        "logging_freq": "epoch"
      },
      "visualization": {
        "use_gradcam": true,
        "use_feature_maps": true
      },
      "early_stopping": {
        "patience": 8,
        "min_delta": 0.001,
        "monitor": "val_f1"
      },
      "checkpointing": {
        "best_only": true,
        "save_frequency": 1,
        "metric": "val_f1"
      }
    },
    "advanced": {
      "seed": 42,
      "deterministic": true,
      "class_weights": "balanced",
      "sampler": "weighted_random",
      "image_channels": 3,
      "tta": {
        "use": true,
        "num_augmentations": 3
      },
      "export_onnx": false,
      "quantization": {
        "use": false,
        "precision": "int8"
      }
    }
  }
}