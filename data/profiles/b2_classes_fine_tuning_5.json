{
  "type": "fine_tuning",
  "info": "Profil dla klasyfikacji wieloklasowej (5 klas)",
  "description": "Profil dostosowany do klasyfikacji około 5 różnych klas",
  "data_required": "Zestaw danych zawierający przykłady z około 5 różnych klas",
  "hardware_required": "Standardowy sprzęt",
  "config": {
    "model": {
      "architecture": "EfficientNet",
      "variant": "b2",
      "input_size": 288,
      "num_classes": 5,
      "pretrained": true,
      "pretrained_weights": "imagenet",
      "feature_extraction_only": false,
      "activation": "relu",
      "dropout_at_inference": false,
      "global_pool": "avg",
      "last_layer_activation": "softmax"
    },
    "training": {
      "epochs": 100,
      "batch_size": 48,
      "learning_rate": 0.0002,
      "optimizer": "AdamW",
      "scheduler": "CosineAnnealingLR",
      "num_workers": 4,
      "warmup_epochs": 10,
      "warmup_lr_init": 1e-6,
      "mixed_precision": true,
      "gradient_accumulation_steps": 1,
      "gradient_clip": 1.0,
      "validation_split": 0.2,
      "evaluation_freq": 1,
      "use_ema": false,
      "ema_decay": 0.9999,
      "unfreeze_strategy": "unfreeze_all",
      "unfreeze_after_epochs": 5,
      "unfreeze_layers": 12,
      "frozen_lr": 0.0001,
      "unfrozen_lr": 0.001
    },
    "regularization": {
      "weight_decay": 0.0001,
      "label_smoothing": 0.05,
      "dropout_rate": 0.4,
      "drop_connect_rate": 0.3,
      "momentum": 0.9,
      "epsilon": 1e-6,
      "swa": {
        "use": true,
        "start_epoch": 80
      },
      "stochastic_depth": {
        "use": false,
        "drop_rate": 0.2,
        "survival_probability": 0.8
      },
      "random_erase": {
        "use": false,
        "probability": 0.25,
        "mode": "pixel"
      }
    },
    "augmentation": {
      "basic": {
        "use": true,
        "rotation": 30,
        "brightness": 0.3,
        "shift": 0.15,
        "zoom": 0.2,
        "horizontal_flip": true,
        "vertical_flip": false
      },
      "mixup": {
        "use": true,
        "alpha": 0.2
      },
      "cutmix": {
        "use": true,
        "alpha": 0.5
      },
      "autoaugment": {
        "use": false
      },
      "randaugment": {
        "use": false,
        "n": 2,
        "m": 9
      },
      "advanced": {
        "contrast": 0.2,
        "saturation": 0.2,
        "hue": 0.1,
        "shear": 0.1,
        "channel_shift": 0.0
      }
    },
    "preprocessing": {
      "normalization": {
        "mean": [0.485, 0.456, 0.406],
        "std": [0.229, 0.224, 0.225]
      },
      "resize_mode": "bilinear",
      "cache_dataset": false
    },
    "monitoring": {
      "metrics": {
        "accuracy": true,
        "precision": true,
        "recall": true,
        "f1": true,
        "topk": true,
        "confusion_matrix": true,
        "auc": true
      },
      "logging": {
        "use_tensorboard": true,
        "use_wandb": false,
        "save_to_csv": true,
        "logging_freq": "epoch"
      },
      "visualization": {
        "use_gradcam": true,
        "use_feature_maps": true,
        "use_pred_samples": true,
        "num_samples": 10
      },
      "early_stopping": {
        "patience": 10,
        "min_delta": 0.001,
        "monitor": "val_loss"
      },
      "checkpointing": {
        "best_only": true,
        "save_frequency": 1,
        "metric": "val_loss"
      }
    },
    "advanced": {
      "seed": 42,
      "deterministic": true,
      "class_weights": "balanced",
      "sampler": "weighted_random",
      "image_channels": 3,
      "tta": {
        "use": false,
        "num_augmentations": 5
      },
      "export_onnx": false,
      "quantization": {
        "use": false,
        "precision": "int8"
      }
    }
  }
}
